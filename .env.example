# Database
DATABASE_URL=postgresql+asyncpg://paychains:password@localhost:5432/paychains
DATABASE_URL_SYNC=postgresql://paychains:password@localhost:5432/paychains
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_EXPIRATION_MINUTES=60

# Wallet Security
WALLET_MASTER_SEED=change-me-encrypted-seed
WALLET_ENCRYPTION_KEY=change-me-aes-256-key-hex

# Blockchain RPC (Testnets for development)
POLYGON_TESTNET_RPC_WS=wss://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
ETHEREUM_TESTNET_RPC_WS=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Blockchain RPC (Mainnet)
ETHEREUM_RPC_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_WS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_WS=wss://bsc-dataseed.binance.org
ARBITRUM_RPC_WS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com
BITCOIN_RPC_URL=https://blockstream.info/api

# Price Feed
COINGECKO_API_KEY=your-key

# DEX (for auto-conversion)
ZEROX_API_KEY=your-key
ONEINCH_API_KEY=your-key

# Email (optional)
RESEND_API_KEY=your-key
FROM_EMAIL=payments@paychains.dev

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
ENVIRONMENT=development
