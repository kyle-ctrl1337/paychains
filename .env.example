# Database
DATABASE_URL=postgresql+asyncpg://paychains:password@localhost:5432/paychains
DATABASE_URL_SYNC=postgresql://paychains:password@localhost:5432/paychains
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-generate-random-64-char-hex
JWT_EXPIRATION_MINUTES=1440

# Blockchain RPC (get keys from alchemy.com)
ETHEREUM_RPC_WS=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_WS=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_WS=https://bnb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_WS=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_WS=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Testnets
POLYGON_TESTNET_RPC_WS=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
ETHEREUM_TESTNET_RPC_WS=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Price Feed (get from coingecko.com/en/api)
COINGECKO_API_KEY=your-coingecko-demo-key

# Email (get from resend.com)
RESEND_API_KEY=re_your_key
FROM_EMAIL=payments@yourdomain.com

# App
APP_URL=https://paychains.dev
API_URL=https://your-backend-url
ENVIRONMENT=development
